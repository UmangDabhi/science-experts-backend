# Application
NODE_ENV=production
PORT=5000
BACKEND_URL=https://your-backend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Database
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_secure_password
DB_DATABASE=scienceexperts_db
DB_SSL=true
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Cloudflare R2 Storage (S3-compatible)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=scienceexperts-uploads
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev
R2_ADDITIONAL_PUBLIC_HOSTS=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRATION=7d

# Signed URL Expiration
SIGNED_URL_EXPIRATION_SECONDS=3600
VIDEO_SIGNED_URL_EXPIRATION_SECONDS=300

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Science Experts <your_email@gmail.com>

# Redis (optional)
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# Payment Gateway
RAZORPAY_MODE=live
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
